{% if _globals.get('primaryNavItems') or _globals.get('topNavItems') %}
	<header id="Header" class="Header py-8 z-50">
		<div class="container Header-wrapper">
			<div class="flex items-center gap-x-10 justify-between z-50 relative">
				<a class="Link" href="{{ siteUrl }}" title="{{ siteName ~ ' ' ~ 'homepage'|t }}">
					{{ svg(include('_partials/icons/logo.svg'))|attr({class: 'w-full h-auto max-w-[150px] pointer-events-all'}) }}
				</a>

				<button class="Toggle js-toggle" title="{{ "Toggle navigatie"|t }}">
					<div class="Toggle-lines">
						<span class="Toggle-line"></span>
						<span class="Toggle-line"></span>
						<span class="Toggle-line"></span>
					</div>
				</button>
			</div>

			<div class="Header-navs">
				<div class="overflow-scroll! Header-navs--inner">
					{% if _globals.get('topNavItems') %}
						{% include "_macros/navigation" with {
							navName: 'TopNav',
							navItems: _globals.get('topNavItems'),
							navClasses: '',
							navLinkClasses: 'Is-link--reversed'
						} %}
					{% endif %}

					{% if _globals.get('primaryNavItems') %}
						{% include "_macros/navigation" with {
							navName: 'MainNav',
							navItems: _globals.get('primaryNavItems'),
							navClasses: '',
							navLinkClasses: 'Is-link--reversed'
						} %}
					{% endif %}
				</div>
			</div>
		</div>
	</header>
{% endif %}