{% extends 'f1/_layout' %}

{% set prevRaces = craft.entries.section('races').orderBy('raceRound desc').raceStatus('completed').limit(3).all() ??? null %}
{% set latestRace = craft.entries.section('races').orderBy('raceRound desc').raceStatus('completed').one() ??? null %}
{% set nextRace = craft.entries.section('races').orderBy('raceRound asc').raceStatus(['selection_open', 'selection_closed']).one() %}
{% set standings = craft.app.getModule('f1-gooat').calculateSeasonStandings() %}

{% block main %}
	<div class="container">
		{% if nextRace %}
			<a href="{{ siteUrl('select/' ~ nextRace.id) }}" class="bg-primary p-5 rounded-2xl Link block">
				<div class="flex flex-col-reverse items-start gap-y-5 gap-x-2 sm:flex-row sm:justify-between">
					<div class="">
						<div class="text-xs font-semibold uppercase tracking-wider text-slate-400">Round
							{{ nextRace.raceRound }}</div>
						<h3 class="font-bold text-lg leading-tight text-white">{{ nextRace.title }}</h3>
					</div>
					{% if nextRace.raceStatus == 'selection_open'%}
						<span class="inline-flex items-center gap-1.5 font-semibold uppercase tracking-wide border rounded-full px-2.5 py-0.5 text-[10px] bg-amber-500/10 text-amber-600 border-amber-500/20">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock w-3 h-3">
								<circle cx="12" cy="12" r="10"></circle>
								<polyline points="12 6 12 12 16 14"></polyline>
							</svg>SELECTION OPEN</span>
					{% endif %}
					{% if nextRace.raceStatus == 'selection_closed'%}
						<span class="inline-flex items-center gap-1.5 font-semibold uppercase tracking-wide border rounded-full px-2.5 py-0.5 text-[10px] bg-green-500/10 text-green-600 border-green-500/20">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock w-3 h-3">
								<circle cx="12" cy="12" r="10"></circle>
								<polyline points="12 6 12 12 16 14"></polyline>
							</svg>Racing!</span>
					{% endif %}
				</div>
				<div class="flex flex-wrap gap-4 text-sm mb-4 text-slate-400">
					<div class="flex items-center gap-1.5">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar w-4 h-4">
							<path d="M8 2v4"></path>
							<path d="M16 2v4"></path>
							<rect width="18" height="18" x="3" y="4" rx="2"></rect>
							<path d="M3 10h18"></path>
						</svg>
						{{ nextRace.raceDate|date('F j, Y') }}</div>

				</div>


				{% set selectedCount = craft.entries().section('predictions').relatedTo({targetElement: nextRace.id, field: 'predictionRace'}).count() %}
				{% set totalPlayers = craft.entries().section('players').count() %}
				{% set totalPercentage = (1 - selectedCount / totalPlayers) * 100 %}
				{% set orderedPlayers = craft.entries().section('players').orderBy('totalPoints asc').all() %}
				{% set currentSelector = orderedPlayers[selectedCount] is defined ? orderedPlayers[selectedCount] : null %}

				<div class="mb-4">
					<div class="space-y-2">
						<div class="flex items-center justify-between text-sm">
							<span class="flex items-center gap-1.5 text-slate-600">

								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users w-4 h-4">
									<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
									<circle cx="9" cy="7" r="4"></circle>
									<path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
									<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
								</svg>
								{% if currentSelector %}
									next voting player:
									<span class="text-amber-600">{{ currentSelector.title }}</span>
								{% else %}
									Voting done!
								{% endif %}
							</span>
							<span class="text-amber-600 tabular-nums">{{ selectedCount }}/{{ totalPlayers }}</span>
						</div>
						<div aria-valuemax="100" aria-valuemin="0" role="progressbar" data-state="indeterminate" data-max="100" class="relative w-full overflow-hidden rounded-full h-2 bg-slate-100">
							<div data-state="indeterminate" data-max="100" class="h-full w-full flex-1 bg-amber-600 transition-all" style="transform: translateX(-{{ '0' }}%);"></div>
						</div>
					</div>
				</div>

				<span class=" cursor-pointer inline-flex items-center justify-center gap-2 rounded-md text-sm transition-colors px-4 py-2 w-full font-semibold bg-slate-900 hover:bg-slate-800 text-white">
					Go to voting
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right w-4 h-4 ml-1">
						<path d="m9 18 6-6-6-6"></path>
					</svg>
				</span>
			</a>
		{% endif %}

		<div class="grid lg:grid-cols-3 gap-8 u-block">
			
            {# Player standings #}
            <div class="{{ prevRaces|length ? 'lg:col-span-2' : 'col-span-3' }}">
				<div class="flex items-center justify-between mb-4">
					<h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trophy w-5 h-5 text-amber-500">
							<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
							<path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
							<path d="M4 22h16"></path>
							<path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path>
							<path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path>
							<path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path>
						</svg>Season Standings</h2>
					<a href="{{ siteUrl('standings') }}">
						<button class="cursor-pointer! inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover:bg-accent hover:text-accent-foreground h-8 rounded-md px-3 text-xs text-slate-500">Full standing
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right w-4 h-4 ml-1">
								<path d="m9 18 6-6-6-6"></path>
							</svg>
						</button>
					</a>
				</div>
				<div class="space-y-2">
					{% for entry in standings %}
						{% set predictionsQuery = craft.entries.section('predictions').predictionPlayer(entry) ??? null %}
						{% set latestScore = clone(predictionsQuery).predictionRace(latestRace).one() ??? null %}
						{% set predictions = clone(predictionsQuery).all() ??? null %}

						<div class="js-player rounded-xl overflow-hidden transition-all bg-white border border-slate-100 hover:border-slate-200" style="transform: none; transform-origin: 50% 50% 0px;">
							<div class="js-player--info flex items-center gap-4 p-4 cursor-pointer border-b border-slate-100">
								<div class="flex items-center justify-center w-10 h-10 rounded-xl font-black text-lg bg-gray-200">
									{{ loop.index}}
								</div>

								<span class="inline-flex items-center justify-center w-8 text-slate-400">
									{% if entry.positionChange > 0 %}
										<span class="text-f1-success text-[11px] font-bold">&uarr;{{ entry.positionChange }}</span>
									{% elseif entry.positionChange < 0 %}
										<span class="text-primary text-[11px] font-bold">&darr;{{ entry.positionChange|abs }}</span>
									{% else %}
										<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-minus w-4 h-4">
											<path d="M5 12h14"></path>
										</svg>
									{% endif %}
								</span>

								<div class="flex-1 min-w-0">
									<div class="flex items-center gap-2">
										<a href="{{ siteUrl('player/' ~ entry.id) }}" class="font-bold text-slate-900 truncate">{{ entry.title }}</a>
										{% if currentPlayer and entry.id == currentPlayer.id %}
											<span class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider bg-green-500 text-white rounded-full">You</span>
										{% endif %}
									</div>
								</div>

								<div class="hidden sm:flex items-center gap-2 text-sm">
									<span class="font-semibold text-emerald-600">+{{ latestScore.pointsEarned }}</span>
								</div>

								<div class="text-right">
									<div class="text-2xl font-black text-slate-900 tabular-nums">{{ entry.totalPoints }}</div>
									<div class="text-[10px] uppercase tracking-wider text-slate-400 font-medium">points</div>
								</div>

								<div class="text-slate-400 js-player--arrow">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down w-5 h-5">
										<path d="m6 9 6 6 6-6"></path>
									</svg>
								</div>

							</div>

							<div class="js-player--details overflow-hidden" style="height: 0; opacity: 0;">
								<div class="p-4 bg-gray-100">
									<div class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-3">Race by Race</div>
									<div class="space-y-2">
										{% for prediction in predictions %}
											<div class="flex items-center justify-between p-3 bg-white rounded-lg">
												<div class="flex items-center gap-3">
													<div>
														<div class="font-medium text-slate-900">{{ prediction.predictionRace.one().title }}</div>
														<div class="text-xs text-slate-500">{{ prediction.driverCode }}
															→ P{{ prediction.actualPosition }}</div>
													</div>
												</div>

												{% if prediction.pointsEarned == 25 %}
													<span class="inline-flex items-center gap-1 font-bold tabular-nums text-sm text-amber-500">
														<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-4 h-4 fill-amber-500">
															<path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
														</svg>
														<span>{{ prediction.pointsEarned }}</span>
													</span>
												{% else %}
													<span class="inline-flex items-center gap-1 font-bold tabular-nums text-sm text-slate-400">
														<span>{{ prediction.pointsEarned }}</span>
													</span>
												{% endif %}
											</div>
										{% endfor %}
									</div>
								</div>
							</div>
						</div>
					{% endfor %}
				</div>
			</div>

			{% if prevRaces|length %}
				<div>
					<div class="flex items-center justify-between mb-4">
						<h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-flag w-5 h-5 text-slate-400">
								<path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path>
								<line x1="4" x2="4" y1="22" y2="15"></line>
							</svg>Recent Races</h2>

						<a href="{{ siteUrl('races') }}">
							<button class="cursor-pointer! inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover:bg-accent hover:text-accent-foreground h-8 rounded-md px-3 text-xs text-slate-500">All Races
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right w-4 h-4 ml-1">
									<path d="m9 18 6-6-6-6"></path>
								</svg>
							</button>
						</a>
					</div>
					<div class="space-y-3">
						{% for race in prevRaces %}
							<div class="rounded-2xl overflow-hidden transition-all duration-300 bg-white border border-slate-200 hover:shadow-lg hover:shadow-slate-100" style="opacity: 1; transform: none;">
								<div class="p-5">
									<div class="flex items-start justify-between mb-4">
										<div class="flex items-center gap-3">
											<div>
												<div class="text-xs font-semibold uppercase tracking-wider text-slate-500">Round
													{{ race.raceRound }}</div>
												<h3 class="font-bold text-lg leading-tight text-slate-900">{{ race.title }}</h3>
											</div>
										</div>
										<span class="inline-flex items-center gap-1.5 font-semibold uppercase tracking-wide border rounded-full px-2.5 py-0.5 text-[10px] bg-emerald-500/10 text-emerald-600 border-emerald-500/20">
											<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-3 h-3">
												<path d="M20 6 9 17l-5-5"></path>
											</svg>COMPLETED</span>
									</div>

									<div class="flex flex-wrap gap-4 text-sm mb-4 text-slate-500">
										<div class="flex items-center gap-1.5">
											<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar w-4 h-4">
												<path d="M8 2v4"></path>
												<path d="M16 2v4"></path>
												<rect width="18" height="18" x="3" y="4" rx="2"></rect>
												<path d="M3 10h18"></path>
											</svg>
											{{ race.raceDate|date('d M, Y')}}</div>
									</div>
									<a href="{{ siteUrl('results/' ~ race.id) }}" class="before:hidden">
										<button class="!cursor-pointer inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 border border-input bg-background shadow-sm hover:bg-accent hover:text-accent-foreground h-9 px-4 py-2 w-full group">View Results<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right w-4 h-4 ml-1 group-hover:translate-x-0.5 transition-transform">
												<path d="m9 18 6-6-6-6"></path>
											</svg>
										</button>
									</a>
								</div>
							</div>
						{% endfor %}
					</div>
				</div>
			{% endif %}
		</div>
	</div>
{% endblock %}