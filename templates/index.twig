{% extends 'f1/_layout' %}

{% block main %}
<div class="container py-12">
    {# Hero #}
    <div class="text-center mb-12">
        <h1 class="text-5xl md:text-6xl font-black uppercase tracking-tight">
            <span class="text-primary">GOOAT</span>
        </h1>
        <p class="text-f1-muted text-lg mt-2">F1 Prediction Game &middot; {{ currentSeasonYear }} Season</p>
    </div>

    {# Player greeting or login prompt #}
    {% if currentPlayer %}
        <div class="F1Card F1Card--highlight text-center mb-10 py-6">
            <p class="text-f1-muted">Welcome back,</p>
            <h2 class="text-2xl font-bold">{{ currentPlayer.title }}</h2>
        </div>
    {% else %}
        <div class="F1Card text-center mb-10 py-6">
            <p class="text-f1-muted mb-4">Login to make your predictions</p>
            <a href="{{ siteUrl('player-login') }}" class="btn btn-primary inline-block px-8 py-3">Login</a>
        </div>
    {% endif %}

    {# ── Build race data ── #}
    {% set allRaces = craft.entries().section('races').orderBy('raceRound asc').all() %}

    {% set pastRaces = [] %}
    {% set futureRaces = [] %}
    {% for race in allRaces %}
        {% if race.raceStatus == 'completed' or race.raceStatus == 'selection_closed' %}
            {% set pastRaces = pastRaces|merge([race]) %}
        {% else %}
            {% set futureRaces = futureRaces|merge([race]) %}
        {% endif %}
    {% endfor %}

    {% set nextRace = futureRaces|length ? futureRaces|first : (pastRaces|length ? pastRaces|last : null) %}

    {# Calendar: 2 past + current/next + 2 upcoming (centered around nextRace) #}
    {% set currentIndex = 0 %}
    {% for race in allRaces %}
        {% if nextRace and race.id == nextRace.id %}
            {% set currentIndex = loop.index0 %}
        {% endif %}
    {% endfor %}
    {% set startIndex = currentIndex - 2 %}
    {% if startIndex < 0 %}{% set startIndex = 0 %}{% endif %}
    {% set endIndex = startIndex + 5 %}
    {% if endIndex > allRaces|length %}{% set endIndex = allRaces|length %}{% endif %}
    {% set startIndex = endIndex - 5 %}
    {% if startIndex < 0 %}{% set startIndex = 0 %}{% endif %}
    {% set calendarRaces = allRaces|slice(startIndex, endIndex - startIndex) %}

    {# ── 3-column dashboard ── #}
    <div class="grid lg:grid-cols-3 gap-6">

        {# ── NEXT RACE ── #}
        <div class="bg-f1-surface rounded-xl border border-f1-border shadow-sm overflow-hidden">
            <div class="h-1 bg-primary"></div>
            <div class="px-7 py-8">
                <h2 class="text-xs font-bold uppercase tracking-widest text-f1-muted mb-8">Next Race</h2>

                {% if nextRace %}
                    {% set isOpen = nextRace.raceStatus == 'selection_open' %}
                    {% set isCompleted = nextRace.raceStatus == 'completed' or nextRace.raceStatus == 'selection_closed' %}

                    <p class="text-primary text-xs font-bold uppercase tracking-wider mb-2">Round {{ nextRace.raceRound }}</p>
                    <h3 class="text-2xl font-black leading-tight">{{ nextRace.title }}</h3>

                    {% if nextRace.raceDate %}
                        <p class="text-f1-muted text-sm mt-1">{{ nextRace.raceDate|date('l, F j \\· Y') }}</p>

                        {% if not isCompleted %}
                            {% set daysLeft = ((nextRace.raceDate|date('U') - now|date('U')) / 86400)|round(0, 'ceil') %}
                            {% if daysLeft > 0 %}
                                <div class="mt-8">
                                    <span class="text-5xl font-black text-secondary">{{ daysLeft }}</span>
                                    <span class="text-f1-muted text-lg ml-1">day{{ daysLeft != 1 ? 's' }} away</span>
                                </div>
                            {% elseif daysLeft == 0 %}
                                <div class="mt-8">
                                    <span class="text-3xl font-black text-f1-success">Race day!</span>
                                </div>
                            {% endif %}
                        {% else %}
                            <p class="text-f1-muted text-sm mt-1">{{ nextRace.raceDate|date('d M Y') }}</p>
                        {% endif %}
                    {% endif %}

                    {% if isOpen %}
                        {% set selectedCount = craft.entries().section('predictions').relatedTo({targetElement: nextRace.id, field: 'predictionRace'}).count() %}
                        {% set totalPlayers = craft.entries().section('players').count() %}
                        {% set selectionComplete = selectedCount >= totalPlayers %}
                        {% set orderedPlayers = craft.entries().section('players').orderBy('totalPoints asc').all() %}
                        {% set currentSelector = orderedPlayers[selectedCount] is defined ? orderedPlayers[selectedCount] : null %}
                        {% set isPlayerTurn = currentSelector and currentPlayer and currentSelector.id == currentPlayer.id %}

                        <div class="mt-6 pt-5 border-t border-f1-border">
                            {% if not selectionComplete %}
                                <p class="text-f1-muted text-xs uppercase tracking-wider mb-1">Now picking</p>
                                <p class="font-bold text-lg {{ isPlayerTurn ? 'text-f1-success' : 'text-secondary' }}">
                                    {{ currentSelector ? currentSelector.title : '—' }}
                                    {% if isPlayerTurn %}
                                        <span class="text-xs font-bold text-f1-success ml-1">(Your turn!)</span>
                                    {% endif %}
                                </p>
                                <p class="text-f1-muted text-sm mt-0.5">{{ selectedCount }}/{{ totalPlayers }} picks</p>
                            {% else %}
                                <p class="text-f1-success font-bold">All picks in!</p>
                            {% endif %}
                        </div>
                    {% endif %}
                {% else %}
                    <p class="text-f1-muted text-center">No races scheduled yet.</p>
                {% endif %}
            </div>
        </div>

        {# ── TOP PLAYERS ── #}
        <div class="bg-f1-surface rounded-xl border border-f1-border shadow-sm overflow-hidden">
            <div class="h-1 bg-f1-perfect"></div>
            <div class="px-7 py-8">
                <h2 class="text-xs font-bold uppercase tracking-widest text-f1-muted mb-8">Top Players</h2>

                {% set standings = craft.app.getModule('f1-gooat').calculateSeasonStandings() %}

                {% if standings|length %}
                    <div class="space-y-2 mb-8">
                        {% for entry in standings %}
                            {% set isMe = currentPlayer and entry.id == currentPlayer.id %}
                            <a href="{{ siteUrl('player/' ~ entry.id) }}"
                               class="flex items-center justify-between py-3 px-4 rounded-lg transition-colors
                                      {{ isMe ? 'ring-2 ring-f1-success/60 bg-f1-success/5' : 'bg-f1-surface-elevated hover:bg-f1-border/30' }}">
                                <div class="flex items-center gap-3">
                                    <span class="w-7 h-7 rounded flex items-center justify-center text-sm font-bold
                                                 {{ loop.index == 1 ? 'bg-f1-success/15 text-f1-success' : 'text-f1-muted' }}">
                                        {{ entry.currentStanding }}
                                    </span>
                                    {% if entry.positionChange > 0 %}
                                        <span class="text-f1-success text-[11px] font-bold">&uarr;{{ entry.positionChange }}</span>
                                    {% elseif entry.positionChange < 0 %}
                                        <span class="text-primary text-[11px] font-bold">&darr;{{ entry.positionChange|abs }}</span>
                                    {% endif %}
                                    <span class="font-semibold text-secondary">
                                        {{ entry.title }}
                                        {% if isMe %}
                                            <span class="ml-1.5 text-[10px] bg-f1-success text-white px-1.5 py-0.5 rounded font-bold uppercase align-middle">You</span>
                                        {% endif %}
                                    </span>
                                </div>
                                <span class="font-mono text-sm text-f1-muted">{{ entry.totalPoints }} pts</span>
                            </a>
                        {% endfor %}
                    </div>

                    <a href="{{ siteUrl('standings') }}" class="block w-full text-center py-3 border-2 border-secondary/20 rounded-lg font-bold text-secondary hover:bg-secondary hover:text-white transition-colors">
                        Full Standings
                    </a>
                {% else %}
                    <p class="text-f1-muted text-center">No players yet.</p>
                {% endif %}
            </div>
        </div>

        {# ── RACE CALENDAR ── #}
        <div class="bg-f1-surface rounded-xl border border-f1-border shadow-sm overflow-hidden">
            <div class="h-1 bg-secondary"></div>
            <div class="px-7 py-8">
                <h2 class="text-xs font-bold uppercase tracking-widest text-f1-muted mb-8">Race Calendar</h2>

                {% if calendarRaces|length %}
                    <div class="space-y-0 mb-8">
                        {% for race in calendarRaces %}
                            {% set isRaceCompleted = race.raceStatus == 'completed' or race.raceStatus == 'selection_closed' %}
                            {% set isRaceOpen = race.raceStatus == 'selection_open' %}

                            {% if isRaceCompleted %}
                                {% set raceUrl = siteUrl('results/' ~ race.id) %}
                            {% elseif isRaceOpen %}
                                {% set raceUrl = siteUrl('select/' ~ race.id) %}
                            {% else %}
                                {% set raceUrl = null %}
                            {% endif %}

                            {% if raceUrl %}
                                <a href="{{ raceUrl }}" class="flex items-center gap-3 py-3 hover:bg-f1-surface-elevated rounded-lg px-1 -mx-1 transition-colors group">
                            {% else %}
                                <div class="flex items-center gap-3 py-3">
                            {% endif %}
                                    <span class="w-8 h-8 rounded-full bg-primary text-white text-[11px] font-bold flex items-center justify-center shrink-0">
                                        R{{ race.raceRound }}
                                    </span>
                                    <span class="font-semibold text-secondary flex-1 text-sm {{ raceUrl ? 'group-hover:text-primary transition-colors' : '' }}">{{ race.title }}</span>
                                    {% if race.raceDate %}
                                        <span class="text-f1-muted text-xs shrink-0">{{ race.raceDate|date('d M') }}</span>
                                    {% endif %}
                                    {% if isRaceCompleted %}
                                        <span class="text-[11px] font-medium text-f1-success bg-f1-success/10 px-2 py-0.5 rounded-full shrink-0">Done</span>
                                    {% elseif isRaceOpen %}
                                        <span class="text-[11px] font-medium text-primary bg-primary/10 px-2 py-0.5 rounded-full shrink-0">Open</span>
                                    {% else %}
                                        <span class="text-[11px] font-medium text-f1-muted bg-f1-surface-elevated px-2 py-0.5 rounded-full shrink-0">Soon</span>
                                    {% endif %}
                            {% if raceUrl %}
                                </a>
                            {% else %}
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>

                    <a href="{{ siteUrl('races') }}" class="block w-full text-center py-3 border-2 border-secondary/20 rounded-lg font-bold text-secondary hover:bg-secondary hover:text-white transition-colors">
                        Full Calendar
                    </a>
                {% else %}
                    <p class="text-f1-muted text-center">No races scheduled yet.</p>
                {% endif %}
            </div>
        </div>

    </div>
</div>
{% endblock %}