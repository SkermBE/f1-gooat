{% set siteLogo = craft.assets().id('319').one() ??? null %}
{% set siteLogoMobile = craft.assets().id('320').one() ??? null %}


<header id="Header" class="fixed top-0 w-full py-8 z-50">
	<div class="container">
		<div
			class="flex items-center justify-between">
			{# Brand #}
			<a href="{{ siteUrl }}" class="flex items-center gap-3 Link">
				{{ svg(include('_partials/icons/logo.svg'))|attr({class: 'max-w-[325px] w-full max-sm:hidden h-auto'}) }}
				{{ svg(include('_partials/icons/icon.svg'))|attr({class: 'max-w-[75px] w-full sm:hidden h-auto'}) }}
			</a>

			{# Mobile toggle #}
			<button class="Toggle js-toggle lg:hidden" title="Toggle navigation">
				<div class="Toggle-lines">
					<span class="Toggle-line"></span>
					<span class="Toggle-line"></span>
					<span class="Toggle-line"></span>
				</div>
			</button>

			{# Navigation #}
			<nav class="Header-navs">
				<div class="Header-navs--inner lg:flex lg:items-center lg:gap-4">
					<ul class="Header-nav-links list-none !p-0 !m-0">
						<li class="list-none">
							<a href="{{ siteUrl('races') }}" class="Header-nav-link Link{% if craft.app.request.segments|first == 'races' %} is-active{% endif %}">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
								<path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path>
								<line x1="4" x2="4" y1="22" y2="15"></line>
							</svg>
							Races
						</a>
						</li>
						<li class="list-none">
							<a href="{{ siteUrl('standings') }}" class="Header-nav-link Link{% if craft.app.request.segments|first == 'standings' %} is-active{% endif %}">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
								<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
								<path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
								<path d="M4 22h16"></path>
								<path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path>
								<path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path>
								<path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path>
							</svg>
							Standings
						</a>
						</li>
					</ul>

					{# Season switcher #}
					{% if availableSites|length > 1 %}
						<div class="relative flex items-center">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 absolute left-3 pointer-events-none max-lg:text-white/80 lg:text-primary">
								<rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
								<line x1="16" x2="16" y1="2" y2="6"></line>
								<line x1="8" x2="8" y1="2" y2="6"></line>
								<line x1="3" x2="21" y1="10" y2="10"></line>
							</svg>
							<select class="Header-nav-select appearance-none pl-9 pr-8 cursor-pointer" onchange="window.location.href=this.value">
								{% for site in availableSites %}
									<option value="{{ site.baseUrl }}" {{ site.id == currentSite.id ? 'selected' }}>{{ site.name }}</option>
								{% endfor %}
							</select>
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 absolute right-3 pointer-events-none max-lg:text-white/80 lg:text-primary">
								<path d="m6 9 6 6 6-6"></path>
							</svg>
						</div>
					{% endif %}

					{# Player indicator / Login #}
					{% if currentPlayer %}
						<div class="flex flex-col items-start lg:items-center gap-3 lg:gap-4 lg:flex-row">
							<a href="{{ siteUrl('player/' ~ currentPlayer.id) }}" class="Header-nav-link Link max-lg:w-full">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
									<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
									<circle cx="12" cy="7" r="4"></circle>
								</svg>
								{{ currentPlayer.title }}
							</a>
							<a href="{{ siteUrl('player-logout') }}?redirect={{ craft.app.request.url|url_encode }}" class="Header-nav-link Header-nav-link--logout Link w-auto">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
									<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
									<polyline points="16 17 21 12 16 7"></polyline>
									<line x1="21" x2="9" y1="12" y2="12"></line>
								</svg>
							</a>
						</div>
					{% else %}
						<button type="button" class="Header-nav-link Header-nav-link--login Link js-login-open">Login</button>
					{% endif %}
				</div>
			</nav>
		</div>
	</div>
</header>

{% if not currentPlayer %}
<div id="LoginModal" class="LoginModal">
	<div class="LoginModal-backdrop js-login-close"></div>
	<div class="LoginModal-content">
		<button type="button" class="LoginModal-close js-login-close">&times;</button>
		<h2 class="text-2xl font-bold text-center mb-6">Login to Play</h2>
		<p class="text-f1-muted text-center mb-8">Enter your email to access the prediction game</p>

		<div id="LoginModal-error" class="F1Login-error hidden"></div>

		<form id="LoginModal-form">
			{{ csrfInput() }}
			<div class="mb-4">
				<label for="login-email" class="block text-sm font-medium mb-2">Email Address</label>
				<input type="email" id="login-email" name="email"
					   class="F1Login-input" placeholder="your@email.com" required>
			</div>
			<button type="submit" class="btn btn-primary w-full text-center py-3">Sign In</button>
		</form>
	</div>
</div>

<script>
(function() {
	var modal = document.getElementById('LoginModal');
	if (!modal) return;

	var form = document.getElementById('LoginModal-form');
	var errorEl = document.getElementById('LoginModal-error');

	document.addEventListener('click', function(e) {
		var btn = e.target.closest('.js-login-open');
		if (btn) {
			e.preventDefault();
			modal.classList.add('is-open');
			modal.querySelector('#login-email').focus();
		}
	});

	document.querySelectorAll('.js-login-close').forEach(function(btn) {
		btn.addEventListener('click', function() {
			modal.classList.remove('is-open');
			errorEl.classList.add('hidden');
		});
	});

	document.addEventListener('keydown', function(e) {
		if (e.key === 'Escape' && modal.classList.contains('is-open')) {
			modal.classList.remove('is-open');
			errorEl.classList.add('hidden');
		}
	});

	form.addEventListener('submit', function(e) {
		e.preventDefault();
		errorEl.classList.add('hidden');

		var formData = new FormData(form);
		formData.append('action', 'f1-gooat/auth/login');

		fetch('/', {
			method: 'POST',
			headers: { 'Accept': 'application/json' },
			body: formData
		})
		.then(function(res) { return res.json(); })
		.then(function(data) {
			if (data.success) {
				window.location.reload();
			} else {
				errorEl.textContent = data.error || 'Login failed.';
				errorEl.classList.remove('hidden');
			}
		})
		.catch(function() {
			errorEl.textContent = 'Something went wrong. Please try again.';
			errorEl.classList.remove('hidden');
		});
	});
})();
</script>
{% endif %}
