{% extends 'f1/_layout' %}

{% block main %}
<div class="F1Login">
    <div class="F1Login-form">
        <h1 class="text-2xl font-bold text-center mb-6">Login to Play</h1>
        <p class="text-f1-muted text-center mb-8">Enter your email to access the prediction game</p>

        {% if error %}
            <div class="F1Login-error">{{ error }}</div>
        {% endif %}

        <form method="post" action="{{ siteUrl('player-login') }}">
            {{ csrfInput() }}
            {{ actionInput('f1-gooat/auth/login') }}
            <input type="hidden" name="redirect" value="{{ returnUrl ?? '' }}">
            <div class="mb-4">
                <label for="email" class="block text-sm font-medium mb-2">Email Address</label>
                <input type="email" id="email" name="email" value="{{ email ?? '' }}"
                       class="F1Login-input" placeholder="your@email.com" required autofocus>
            </div>
            <button type="submit" class="btn btn-primary w-full text-center py-3">Sign In</button>
        </form>
    </div>
</div>
{% endblock %}