{% extends 'f1/_layout' %}

{% set perfectScores = craft.entries.section('predictions').predictionPlayer(player).pointsEarned('25').ids %}
{% set completedRaces = craft.entries.section('races').raceStatus('completed').ids %}

{% set averageScore = completedRaces|length ? player.totalPoints / completedRaces|length : 0 %}


{% block main %}
	<div class="container container-sm mb-20">
		<div class="mb-6">
			<a href="{{ siteUrl('standings') }}">
				<button class="!cursor-pointer inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover:bg-accent hover:text-accent-foreground h-8 rounded-md px-3 text-xs text-slate-500 mb-4">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left w-4 h-4 mr-1">
						<path d="m12 19-7-7 7-7"></path>
						<path d="M19 12H5"></path>
					</svg>Standing</button>
			</a>

			<div class="flex items-center gap-4 mb-2">
				<div>
					<h1 class="text-2xl sm:text-3xl font-black text-slate-900">{{ player.title }}</h1>
				</div>
			</div>
		</div>


		<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">

			<div class="rounded-xl border bg-white text-card-foreground shadow">
				<div class="p-6 pt-6 text-center">
					<div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center mx-auto mb-2">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trophy w-5 h-5 text-amber-500">
							<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
							<path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
							<path d="M4 22h16"></path>
							<path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path>
							<path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path>
							<path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path>
						</svg>
					</div>
					<div class="text-3xl font-black text-slate-900">#{{ player.currentStanding }}</div>
					<div class="text-xs text-slate-500 mt-0.5">Standing</div>
				</div>

			</div>

			<div class="rounded-xl border bg-white text-card-foreground shadow">
				<div class="p-6 pt-6 text-center">
					<div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center mx-auto mb-2">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-up w-5 h-5 text-blue-500">
							<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline>
							<polyline points="16 7 22 7 22 13"></polyline>
						</svg>
					</div>
					<div class="text-3xl font-black text-slate-900">{{ player.totalPoints }}</div>
					<div class="text-xs text-slate-500 mt-0.5">Total Points</div>
				</div>

			</div>

			<div class="rounded-xl border bg-white text-card-foreground shadow">
				<div class="p-6 pt-6 text-center">
					<div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center mx-auto mb-2">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-target w-5 h-5 text-emerald-500">
							<circle cx="12" cy="12" r="10"></circle>
							<circle cx="12" cy="12" r="6"></circle>
							<circle cx="12" cy="12" r="2"></circle>
						</svg>
					</div>
					<div class="text-3xl font-black text-slate-900">{{ perfectScores|length }}</div>
					<div class="text-xs text-slate-500 mt-0.5">Perfect P10s</div>

				</div>
			</div>

			<div class="rounded-xl border bg-white text-card-foreground shadow">
				<div class="p-6 pt-6 text-center">
					<div class="w-10 h-10 rounded-xl bg-purple-50 flex items-center justify-center mx-auto mb-2">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chart-no-axes-column w-5 h-5 text-purple-500">
							<line x1="18" x2="18" y1="20" y2="10"></line>
							<line x1="12" x2="12" y1="20" y2="4"></line>
							<line x1="6" x2="6" y1="20" y2="14"></line>
						</svg>
					</div>
					<div class="text-3xl font-black text-slate-900">{{ averageScore|round(2) }}</div>
					<div class="text-xs text-slate-500 mt-0.5">Avg Points</div>

				</div>
			</div>
		</div>

		<div class="MainGrid gap-y-10">


			<div class="col-span-full sm:col-span-7 rounded-xl border bg-white text-card-foreground shadow">
				<div class="flex flex-col space-y-1.5 p-6">
					<div class="font-semibold tracking-tight text-lg">Race History</div>
				</div>
				<div class="p-6 pt-0">
					<div class="space-y-2">
						{% for entry in raceHistory %}
							{% set hasResults = entry.prediction.predictionRace.one().raceResults|length > 1 %}
							<div class="flex items-center justify-between p-3 {{ hasResults ? 'bg-slate-50' : 'bg-amber-50/50 border border-dashed border-amber-200' }} rounded-xl hover:bg-gray-100 transition-colors">
								<div class="flex items-center gap-3">
									<div>
										<p class="text-slate-500 !text-[10px]">Round
											{{ entry.race.raceRound }}</p>
										{% if hasResults %}
											<a href="{{ siteUrl('results/' ~ entry.race.id) }}" class="font-medium text-slate-900">{{ entry.race }}</a>
										{% else %}
											<span class="font-medium text-slate-900">{{ entry.race }}</span>
										{% endif %}
										<div class="text-xs text-slate-500">
											{% if hasResults %}
												{{ entry.prediction.driverCode ~ ' → ' ~ (entry.prediction.actualPosition is null ? 'DNF' : 'P' ~ entry.prediction.actualPosition )}}
											{% else %}
												{{ entry.prediction.driverCode }}
											{% endif %}
										</div>
									</div>
								</div>

								{% if not hasResults %}
									<span class="inline-flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-wide text-amber-600 bg-amber-500/10 border border-amber-500/20 rounded-full px-2.5 py-0.5">
										<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3">
											<circle cx="12" cy="12" r="10"></circle>
											<polyline points="12 6 12 12 16 14"></polyline>
										</svg>
										Pending
									</span>
								{% elseif entry.prediction.pointsEarned == 25 %}
									<span class="inline-flex items-center gap-1 font-bold tabular-nums text-sm text-amber-500">
										<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-4 h-4 fill-amber-500">
											<path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
										</svg>
										<span>{{ entry.prediction.pointsEarned }}</span>
									</span>
								{% else %}
									<span class="inline-flex items-center gap-1 font-bold tabular-nums text-sm text-slate-400">
										<span>{{ entry.prediction.pointsEarned }}</span>
									</span>
								{% endif %}
							</div>
						{% endfor %}
					</div>
				</div>
			</div>


			<div class="col-span-full sm:col-span-5">
				<div class="rounded-xl border bg-card text-card-foreground shadow">
					<div class="flex flex-col space-y-1.5 p-6 pb-2">
						<div class="font-semibold tracking-tight text-lg">Most Picked Drivers</div>
					</div>
					<div class="p-6 pt-0">
						<div class="space-y-3">
							{% for code, count in driverPicks %}
								<div class="flex items-center gap-3">
									<div class="w-10 text-xs font-black text-slate-700 text-right">{{ code }}</div>
									<div class="flex-1 relative h-8 bg-slate-100 rounded-lg overflow-hidden group">
										<div class="h-full rounded-lg transition-all duration-700 bg-amber-500 group-hover:bg-amber-300" style="width: {{ (count / driverPicks|first * 100) }}%;"></div>
										<div class="absolute inset-0 flex items-center px-3">
											<span class="text-xs font-semibold text-slate-700">{{ code }}</span>
										</div>
									</div>
									<div class="w-12 text-right">
										<div class="text-xs font-black text-slate-800">{{ count }}x</div>
										{# <div class="text-[10px] text-slate-400">25pts</div> #}
									</div>
								</div>
							{% endfor %}

						</div>
					</div>
				</div>
			</div>


		</div>
	</div>
{% endblock %}
