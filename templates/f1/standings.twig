{% extends 'f1/_layout' %}

{% set completedRaces = craft.entries.section('races').raceStatus('completed').ids %}
{% set perfectScores = craft.entries.section('predictions').pointsEarned('25').ids %}
{% set latestRace = craft.entries.section('races').orderBy('raceRound desc').raceStatus('completed').one() ??? null %}

{% block main %}
	<div class="container container-sm mb-20">

		<div class="mb-8">
			<a href="{{ siteUrl() }}">
				<button class="!cursor-pointer inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover:bg-accent hover:text-accent-foreground h-8 rounded-md px-3 text-xs text-slate-500 mb-4">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left w-4 h-4 mr-1">
						<path d="m12 19-7-7 7-7"></path>
						<path d="M19 12H5"></path>
					</svg>Back</button>
			</a>
			<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
				<div>
					<h1 class="text-2xl sm:text-3xl font-black text-slate-900 flex items-center gap-3">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trophy w-8 h-8 text-amber-500">
							<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
							<path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
							<path d="M4 22h16"></path>
							<path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path>
							<path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path>
							<path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path>
						</svg>Season Standings</h1>
					<p class="text-slate-500 mt-1">Season
						{{ currentSeasonYear }}</p>
				</div>
			</div>
		</div>
		<div class="grid grid-cols-3 gap-4 mb-8">
			<div class="bg-white rounded-2xl p-4 sm:p-6 border border-slate-100" style="opacity: 1; transform: none;">
				<div class="flex items-center gap-3 mb-2">
					<div class="p-2 rounded-xl bg-slate-100">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-up w-5 h-5 text-slate-600">
							<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline>
							<polyline points="16 7 22 7 22 13"></polyline>
						</svg>
					</div>
				</div>
				<div class="text-2xl sm:text-3xl font-black text-slate-900">{{ completedRaces|length }}</div>
				<div class="text-xs sm:text-sm text-slate-500">Races Completed</div>
			</div>
			<div class="bg-white rounded-2xl p-4 sm:p-6 border border-slate-100" style="opacity: 1; transform: none;">
				<div class="flex items-center gap-3 mb-2">
					<div class="p-2 rounded-xl bg-amber-100">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-target w-5 h-5 text-amber-600">
							<circle cx="12" cy="12" r="10"></circle>
							<circle cx="12" cy="12" r="6"></circle>
							<circle cx="12" cy="12" r="2"></circle>
						</svg>
					</div>
				</div>
				<div class="text-2xl sm:text-3xl font-black text-slate-900">{{ perfectScores|length }}</div>
				<div class="text-xs sm:text-sm text-slate-500">Perfect P10s</div>
			</div>
			<div class="bg-white rounded-2xl p-4 sm:p-6 border border-slate-100" style="opacity: 1; transform: none;">
				<div class="flex items-center gap-3 mb-2">
					<div class="p-2 rounded-xl bg-blue-100">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trophy w-5 h-5 text-blue-600">
							<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
							<path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
							<path d="M4 22h16"></path>
							<path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path>
							<path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path>
							<path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path>
						</svg>
					</div>
				</div>
				<div class="text-2xl sm:text-3xl font-black text-slate-900">{{ standings|length }}</div>
				<div class="text-xs sm:text-sm text-slate-500">Players</div>
			</div>
		</div>

		<div class="space-y-2">
			{% for entry in standings %}
				{% include "f1/_partials/playerStanding" %}
			{% endfor %}
		</div>
	</div>
{% endblock %}
